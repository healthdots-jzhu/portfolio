# Copy this file to `.env` and fill in secrets for local container runs.
# Do NOT commit your `.env` file to source control.

##############################################
# Required / Recommended environment variables
##############################################

## Database (preferred)
## This value maps to `ConnectionStrings:Postgres` in the app configuration.
## Example (RDS):
ConnectionStrings__Postgres=Host=your-rds-host;Port=5432;Database=portfoliodb;Username=postgres;Password=yourpassword;Include Error Detail=true

## AWS credentials (choose one approach)
## Option A: reference an AWS profile (requires mounting ~/.aws or having the profile available inside the container)
AWS_PROFILE=your-aws-profile

## Option B: supply explicit AWS credentials (less secure; avoid committing)
#AWS_ACCESS_KEY_ID=
#AWS_SECRET_ACCESS_KEY=
#AWS_SESSION_TOKEN=

## AWS region used by the SDK (also mapped into app settings)
AWS_REGION=ca-central-1

## S3 bucket used by the app (maps to Aws:S3:BucketName)
AWS_S3_BUCKET=healthdots-portfolio-web-app-001

## Hashids salt lookup (optional)
## If you want the app to fetch the salt from SSM Parameter Store, set the SSM path here.
## NOTE: the application expects `Hashids:ParameterName` ŌĆö in environment variables that becomes `Hashids__ParameterName`.
HASHIDS_PARAMETER=/portfolio/hashids/salt

## Alternatively, provide the salt directly (bypasses SSM):
#Hashids__Salt=your-manual-salt-value

## Runtime environment
ASPNETCORE_ENVIRONMENT=Development

##############################################
# Notes: env -> appsettings mapping
##############################################
# - .NET configuration maps JSON keys with ':' to environment variables using '__' (double underscore).
#   Example: `Aws:S3:BucketName` -> `Aws__S3__BucketName`.
# - Docker Compose `.env` is used for variable substitution (e.g. ${AWS_PROFILE}).
#   To make variables available inside the container process, we map them explicitly in `docker-compose.yml`.
# - Keys used by the app (examples you may want to set):
#   - ConnectionStrings__Postgres           (ConnectionStrings:Postgres)
#   - Aws__Profile                          (Aws:Profile)
#   - Aws__Region                           (Aws:Region)
#   - Aws__S3__BucketName                   (Aws:S3:BucketName)
#   - Hashids__ParameterName                (Hashids:ParameterName) OR Hashids__Salt
#   - AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_SESSION_TOKEN  (standard AWS SDK env vars)

##############################################
# Security
##############################################
# - Do NOT commit `.env` to source control. Use `.env.example` as the template.
# - For local development using SSO profiles, mounting your host `~/.aws` into the container helps the AWS SDK resolve profiles.
# - For production, use IAM roles / secrets manager rather than environment variables.

